def hex_bgr(h):
    h=h.lstrip("#"); return (int(h[4:6],16),int(h[2:4],16),int(h[0:2],16))


class EMA:
    """Per-key exponential moving average — smooths landmarks, segmentation, waistband."""
    def __init__(self, alpha=0.25): self.a=alpha; self.state={}
    def reset(self): self.state={}
    def update(self, key, val):
        if key not in self.state:
            self.state[key] = val.copy() if hasattr(val,'copy') else float(val)
        else:
            if hasattr(val,'copy'): self.state[key] = self.a*val + (1-self.a)*self.state[key]
            else: self.state[key] = self.a*float(val) + (1-self.a)*self.state[key]
        return self.state[key]


def detect_waistband(frame, seg_bin, hip_y, ls_x, rs_x, h, w):
    """
    Scan a vertical saturation profile through the torso center.
    Shirt=white (sat≈0), pants=colored (sat>0).
    Waistband = row with biggest positive saturation jump below hip landmark.
    """
    cx = int(np.clip((ls_x+rs_x)//2, 40, w-40))
    ry, sats = [], []
    for y in range(max(0, hip_y-int(h*.05)), min(h-1, hip_y+int(h*.38))):
        if seg_bin[y, cx] == 0: continue
        x0, x1 = max(0,cx-50), min(w,cx+50)
        ins = frame[y,x0:x1][seg_bin[y,x0:x1]>0]
        if len(ins) < 10: continue
        hsv = cv2.cvtColor(ins.reshape(1,-1,3), cv2.COLOR_BGR2HSV)[0]
        ry.append(y); sats.append(float(hsv[:,1].mean()))
    if len(ry) < 20: return hip_y + int(h*.15)
    ry = np.array(ry)
    ss = uniform_filter1d(np.array(sats), size=15)
    d  = np.diff(ss)
    si = np.searchsorted(ry, hip_y)
    if si < len(d)-5: return int(ry[int(np.argmax(d[si:]))+si])
    return hip_y + int(h*.15)


def cc_seed(zone, sx, sy, h, w):
    """Return CC containing (sx,sy), or largest CC if seed misses."""
    sx, sy = int(np.clip(sx,1,w-2)), int(np.clip(sy,1,h-2))
    if zone.sum() == 0: return np.zeros((h,w), np.uint8)
    _, labels, stats, _ = cv2.connectedComponentsWithStats(zone)
    lbl = int(labels[sy, sx])
    if lbl > 0: return (labels==lbl).astype(np.uint8)*255
    best = int(np.argmax(stats[1:, cv2.CC_STAT_AREA])+1)
    return (labels==best).astype(np.uint8)*255


def get_skin_mask(frame, lower_skin=None, upper_skin=None):
    """
    Returns a binary mask of skin pixels using HSV thresholds.
    Default thresholds work for many skin tones under good lighting.
    """
    if lower_skin is None:
        lower_skin = np.array([0, 20, 70], dtype=np.uint8)
    if upper_skin is None:
        upper_skin = np.array([20, 150, 255], dtype=np.uint8)
    hsv = cv2.cvtColor(frame, cv2.COLOR_BGR2HSV)
    mask = cv2.inRange(hsv, lower_skin, upper_skin)
    mask = cv2.morphologyEx(mask, cv2.MORPH_OPEN, np.ones((3,3), np.uint8))
    mask = cv2.morphologyEx(mask, cv2.MORPH_CLOSE, np.ones((5,5), np.uint8))
    return mask


def get_5masks(frame, lm_s, seg_s, wb_s):
    h, w = frame.shape[:2]
    vis = lm_s[:,3]

    def ly(i, fb): return int(lm_s[i,1]/256*h) if vis[i]>0.15 else fb
    def lx(i, fb): return int(lm_s[i,0]/256*w) if vis[i]>0.15 else fb

    # --- Head (unchanged, above eyes) ---
    nose_x, nose_y = lx(0, w//2), ly(0, int(h*.15))
    eye_ys = [ly(i,0) for i in range(1,7) if vis[i]>0.15]
    eye_y_min = min(eye_ys) if eye_ys else nose_y

    # --- Shirt: neck to waistband (unchanged) ---
    ls_x, ls_y = lx(11, int(w*.38)), ly(11, int(h*.38))
    rs_x, rs_y = lx(12, int(w*.62)), ly(12, int(h*.38))
    shoulder_y = min(ls_y, rs_y)
    # Estimate neck (same as before)
    mouth_y = None
    if vis[9] > 0.15 and vis[10] > 0.15:
        mouth_y = (ly(9,0) + ly(10,0)) // 2
    ear_y = None
    if vis[7] > 0.15 and vis[8] > 0.15:
        ear_y = (ly(7,0) + ly(8,0)) // 2
    if mouth_y is not None:
        neck_y = int(mouth_y + (shoulder_y - mouth_y) * 0.3)
    elif ear_y is not None:
        neck_y = int(ear_y + (shoulder_y - ear_y) * 0.4)
    else:
        neck_y = shoulder_y - int(h * 0.05)
    neck_y = max(0, min(neck_y, shoulder_y))

    # --- Prepare segmentation binary ---
    seg_u8 = (seg_s * 255).astype(np.uint8)
    seg_bin = cv2.morphologyEx(
        cv2.threshold(seg_u8, 120, 255, cv2.THRESH_BINARY)[1],
        cv2.MORPH_CLOSE, np.ones((9,9), np.uint8))
    k3 = np.ones((3,3), np.uint8)

    # --- Head mask ---
    hz = seg_bin.copy()
    hz[min(h, eye_y_min - int(h*0.02)):, :] = 0
    head = cc_seed(hz, nose_x, max(10, eye_y_min-30), h, w)

    # --- Shirt mask ---
    sz = seg_bin.copy()
    sz[:max(0, neck_y), :] = 0
    sz[min(h, wb_s + int(h*0.01)):, :] = 0
    seed_x = (ls_x + rs_x) // 2
    seed_y = min(shoulder_y, neck_y + int(h*0.05))
    shirt = cc_seed(sz, seed_x, seed_y, h, w)
    shirt = cv2.subtract(shirt, head)

    # --- Pants: robust detection using landmarks and color ---
    # Gather lower body landmarks
    lhip = (lx(23, ls_x), ly(23, h//2))
    rhip = (lx(24, rs_x), ly(24, h//2))
    lknee = (lx(25, lhip[0]), ly(25, h*3//4))
    rknee = (lx(26, rhip[0]), ly(26, h*3//4))
    lankle = (lx(27, lhip[0]), ly(27, h-10))
    rankle = (lx(28, rhip[0]), ly(28, h-10))

    # Determine top of pants region (waistband)
    top_y = wb_s
    # Determine bottom (use knees if visible and above ankles, else ankles)
    bottom_y = h-1
    if vis[25] > 0.15 or vis[26] > 0.15:
        knee_y = max(ly(25,0), ly(26,0))
        if knee_y > top_y + 20:   # knee should be below waist
            bottom_y = min(bottom_y, knee_y + int(h*0.03))
    # Ankles as fallback
    ankle_y = max(ly(27,0), ly(28,0))
    if ankle_y > top_y + 20:
        bottom_y = min(bottom_y, ankle_y + int(h*0.03))
    else:
        bottom_y = min(h-1, top_y + int(h*0.6))   # fallback if no landmarks

    # Determine left/right bounds using hip/knee/ankle x positions
    xs = []
    for (x,_) in [lhip, rhip, lknee, rknee, lankle, rankle]:
        if x > 0 and x < w:
            xs.append(x)
    if len(xs) >= 2:
        left_x = max(0, min(xs) - int(w*0.05))
        right_x = min(w, max(xs) + int(w*0.05))
    else:
        # fallback to waistband row width
        wb_row = seg_bin[min(h-1, top_y), :]
        nz = np.where(wb_row > 0)[0]
        if len(nz):
            left_x = max(0, nz[0] - int(w*0.03))
            right_x = min(w, nz[-1] + int(w*0.03))
        else:
            left_x, right_x = int(w*0.2), int(w*0.8)

    # Create initial pants zone
    pz = seg_bin.copy()
    pz[:max(0, top_y - 5), :] = 0
    pz[min(h, bottom_y):, :] = 0
    pz[:, :left_x] = 0
    pz[:, right_x:] = 0
    # Remove head and shirt
    pz = cv2.subtract(pz, cv2.bitwise_or(head, shirt))

    # Optional: color-based refinement to keep only pixels that look like pants
    # Sample a small patch just below the waistband (center of bounding box) to get dominant color
    sample_x = (left_x + right_x) // 2
    sample_y = min(h-1, top_y + 20)
    sample_w = 30
    sample_rect = frame[max(0,sample_y-10):min(h,sample_y+10),
                        max(0,sample_x-15):min(w,sample_x+15)]
    if sample_rect.size > 0:
        # Convert to HSV and compute median hue, saturation
        hsv_rect = cv2.cvtColor(sample_rect, cv2.COLOR_BGR2HSV).reshape(-1,3)
        median_hue = np.median(hsv_rect[:,0])
        # Allow a hue range around the median
        hue_low = max(0, median_hue - 15)
        hue_high = min(180, median_hue + 15)
        # Create color mask for the whole pants zone
        hsv_full = cv2.cvtColor(frame, cv2.COLOR_BGR2HSV)
        color_mask = cv2.inRange(hsv_full, (hue_low, 30, 30), (hue_high, 255, 255))
        # Keep only pixels that are both in pz and have pants-like color
        pz = cv2.bitwise_and(pz, color_mask)

    # Now find the largest connected component inside pz (seed at sample point)
    if np.any(pz):
        # Use sample point as seed if it's inside pz, else fallback to center
        if pz[sample_y, sample_x] > 0:
            seed_pt = (sample_x, sample_y)
        else:
            seed_pt = ((left_x+right_x)//2, (top_y+bottom_y)//2)
        pants = cc_seed(pz, seed_pt[0], seed_pt[1], h, w)
    else:
        pants = np.zeros((h,w), dtype=np.uint8)

    # Clean masks
    for m in [head, shirt, pants]:
        cv2.morphologyEx(m, cv2.MORPH_OPEN, k3, dst=m)

    # --- Remove skin ---
    skin_mask = get_skin_mask(frame)
    skin_inv = cv2.bitwise_not(skin_mask)
    head  = cv2.bitwise_and(head, skin_inv)
    shirt = cv2.bitwise_and(shirt, skin_inv)
    pants = cv2.bitwise_and(pants, skin_inv)

    # Return five masks (arms empty)
    larm = np.zeros((h,w), dtype=np.uint8)
    rarm = np.zeros((h,w), dtype=np.uint8)
    return head, larm, rarm, shirt, pants


def delaunay(mask, extra_pts, w, h, gs):
    cnts,_ = cv2.findContours(mask, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_NONE)
    mc = None; cp = []
    if cnts:
        mc   = max(cnts, key=cv2.contourArea)
        simp = cv2.approxPolyDP(mc, 3, True)
        step = max(1, len(simp)//60)
        cp   = [(int(simp[i][0][0]), int(simp[i][0][1]))
                for i in range(0, len(simp), step)
                if 0 < simp[i][0][0] < w and 0 < simp[i][0][1] < h]
    mn = mask.astype(np.float32)/255
    ip = [(gx,gy) for gy in range(gs,h-gs,gs)
                  for gx in range(gs,w-gs,gs) if mn[gy,gx] > 0.5]
    pts = list(set(extra_pts + cp + ip))
    if len(pts) < 4: return [], mc
    sd = cv2.Subdiv2D((0,0,w,h))
    for p in pts:
        try: sd.insert(p)
        except: pass
    tris = []
    for x1,y1,x2,y2,x3,y3 in sd.getTriangleList():
        cx=(int(x1)+int(x2)+int(x3))//3; cy=(int(y1)+int(y2)+int(y3))//3
        if 0<cx<w and 0<cy<h and mn[cy,cx] > 0.35:
            tris.append((int(x1),int(y1),int(x2),int(y2),int(x3),int(y3)))
    return tris, mc


def draw_layer(canvas, tris, outline, color, lt, fa):
    if not tris: return
    ov = canvas.copy()
    fc = tuple(max(0, int(c*0.06)) for c in color)
    for x1,y1,x2,y2,x3,y3 in tris:
        cv2.fillPoly(ov, [np.array([[x1,y1],[x2,y2],[x3,y3]])], fc)
    canvas[:] = cv2.addWeighted(canvas, 1-fa, ov, fa, 0)
    for x1,y1,x2,y2,x3,y3 in tris:
        cv2.polylines(canvas, [np.array([[x1,y1],[x2,y2],[x3,y3]])], True, color, lt)
    if outline is not None:
        cv2.drawContours(canvas, [outline], -1, color, 2)


def process_frame(frame, interp, ema, cfg):
    h, w = frame.shape[:2]
    inp = cv2.cvtColor(cv2.resize(frame,(256,256)),cv2.COLOR_BGR2RGB).astype(np.float32)/255
    interp.set_tensor(interp.get_input_details()[0]["index"], inp[np.newaxis])
    interp.invoke()
    lm  = interp.get_tensor(696)[0].reshape(39,5).copy()
    seg = interp.get_tensor(565)[0,:,:,0]
    prs = float(interp.get_tensor(701)[0,0])
    lm[:,3]=1/(1+np.exp(-lm[:,3])); lm[:,4]=1/(1+np.exp(-lm[:,4]))
    seg_up = cv2.resize(1/(1+np.exp(-seg)), (w,h))

    if not (prs > 0.3 or np.mean(lm[:,3][:17]) > 0.3):
        ema.reset(); return frame

    vis = lm[:,3]
    def ly(i,fb): return int(lm[i,1]/256*h) if vis[i]>0.15 else fb
    def lx(i,fb): return int(lm[i,0]/256*w) if vis[i]>0.15 else fb
    hip_y = max(ly(23,int(h*.60)), ly(24,int(h*.60)))
    ls_x  = lx(11,int(w*.38)); rs_x = lx(12,int(w*.62))

    # Detect waistband on raw (unsmoothed) frame
    seg_rb = cv2.morphologyEx(
        cv2.threshold((seg_up*255).astype(np.uint8),120,255,cv2.THRESH_BINARY)[1],
        cv2.MORPH_CLOSE, np.ones((9,9),np.uint8))
    wb = detect_waistband(frame, seg_rb, hip_y, ls_x, rs_x, h, w)

    # Smooth all signals
    lm_s   = ema.update('lm',  lm)
    seg_s  = ema.update('seg', seg_up)
    wb_s   = int(ema.update('wb', float(wb)))

    hm, lam, ram, sm, pm = get_5masks(frame, lm_s, seg_s, wb_s)

    vs = lm_s[:,3]
    lm_pts = [(int(lm_s[i,0]/256*w), int(lm_s[i,1]/256*h))
              for i in range(39) if vs[i]>0.15
              and 3<lm_s[i,0]/256*w<w-3 and 3<lm_s[i,1]/256*h<h-3]
    def inn(pts, mask): return [(x,y) for x,y in pts if 0<=y<h and 0<=x<w and mask[y,x]>127]

    gs = cfg["gs"]; lt = cfg["lt"]
    canvas = frame.copy()

    # Draw order: head → arms → pants → shirt (primary, drawn last = most visible)
    ht,hc = delaunay(hm,  inn(lm_pts,hm),  w,h,gs); draw_layer(canvas,ht,hc,  cfg["head"], lt,0.06)
    lt2,lc= delaunay(lam, inn(lm_pts,lam), w,h,gs); draw_layer(canvas,lt2,lc, cfg["arm"],  lt,0.06)
    rt2,rc= delaunay(ram, inn(lm_pts,ram), w,h,gs); draw_layer(canvas,rt2,rc, cfg["arm"],  lt,0.06)
    pt,pc = delaunay(pm,  inn(lm_pts,pm),  w,h,gs); draw_layer(canvas,pt,pc,  cfg["pants"],lt,0.09)
    st2,sc= delaunay(sm,  inn(lm_pts,sm),  w,h,gs); draw_layer(canvas,st2,sc, cfg["shirt"],lt,0.15)

    if cfg["nodes"]:
        for px,py in lm_pts:
            cv2.circle(canvas,(px,py),4,(0,255,180),-1)
            cv2.circle(canvas,(px,py),2,(255,255,255),-1)
    return canvas


