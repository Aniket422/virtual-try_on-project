if uploaded:
    st.video(uploaded)
    if st.button("▶️ Generate Mesh Video", type="primary", use_container_width=True):
        cfg = dict(
            shirt = hex_bgr(shirt_hex),
            pants = hex_bgr(pants_hex),
            arm   = hex_bgr(arm_hex),
            head  = hex_bgr(head_hex),
            gs    = grid_step,
            lt    = line_thick,
            nodes = show_nodes,
        )
        tmp = tempfile.NamedTemporaryFile(delete=False, suffix=".mp4")
        tmp.write(uploaded.read()); tmp.close()

        cap  = cv2.VideoCapture(tmp.name)
        fps  = cap.get(cv2.CAP_PROP_FPS) or 25
        ow_  = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))
        oh_  = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))
        tot  = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))
        sc   = output_w / max(ow_,1)
        ow, oh = output_w, int(oh_*sc) & ~1

        raw = tempfile.NamedTemporaryFile(delete=False, suffix=".mp4").name
        wrt = cv2.VideoWriter(raw, cv2.VideoWriter_fourcc(*"mp4v"), fps, (ow,oh))

        ema  = EMA(alpha=smooth_alpha)
        prog = st.progress(0, "Starting…"); prev = st.empty()
        t0 = time.time(); fi = 0

        while True:
            ret, frame = cap.read()
            if not ret: break
            out = process_frame(cv2.resize(frame,(ow,oh)), LM, ema, cfg)
            wrt.write(out); fi += 1
            el  = time.time()-t0; pf = fi/max(el,1e-3); eta = (tot-fi)/max(pf,1e-3)
            prog.progress(min(fi/max(tot,1),1.0),
                         text=f"Frame {fi}/{tot} · {pf:.1f} fps · ETA {eta:.0f}s")
            if fi % 20 == 0:
                prev.image(cv2.cvtColor(out,cv2.COLOR_BGR2RGB), use_container_width=True)

        cap.release(); wrt.release(); prog.empty(); prev.empty()

        out264 = tempfile.NamedTemporaryFile(delete=False, suffix=".mp4").name
        with st.spinner("Re-encoding to H.264…"):
            _sp.run([FFMPEG,"-y","-i",raw,
                     "-c:v","libx264","-preset","fast","-crf","22",
                     "-movflags","+faststart",out264],
                    capture_output=True, check=False)

        el = time.time()-t0
        st.success(f"✅ Done — {fi} frames · {el:.1f}s · {fi/el:.1f} fps")
        vf = out264 if os.path.exists(out264) and os.path.getsize(out264)>1000 else raw
        with open(vf,"rb") as f:
            st.download_button("📥 Download Mesh Video", f.read(),
                               "5region_mesh.mp4","video/mp4", use_container_width=True)
        for p in [tmp.name, raw]:
            try: os.unlink(p)
            except: pass
