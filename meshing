def hex_bgr(h):
    h=h.lstrip("#"); return (int(h[4:6],16),int(h[2:4],16),int(h[0:2],16))

class EMA:
    def __init__(self,alpha=0.25): self.a=alpha; self.s={}
    def reset(self): self.s={}
    def upd(self,k,v):
        if k not in self.s: self.s[k]=v.copy() if hasattr(v,"copy") else float(v)
        else:
            if hasattr(v,"copy"): self.s[k]=self.a*v+(1-self.a)*self.s[k]
            else: self.s[k]=self.a*float(v)+(1-self.a)*self.s[k]
        return self.s[k]

def detect_wb(frame,seg_bin,sh_y,h,w):
    """Scan full body width per row. Median sat. Largest gradient = shirt→pants."""
    ry,sats=[],[]
    for y in range(sh_y,h-10):
        row=seg_bin[y,:]; nz=np.where(row>0)[0]
        if len(nz)<20: continue
        strip=frame[y,int(nz[0]):int(nz[-1])]
        if len(strip)<10: continue
        hsv=cv2.cvtColor(strip.reshape(1,-1,3),cv2.COLOR_BGR2HSV)[0]
        ry.append(y); sats.append(float(np.median(hsv[:,1])))
    if len(ry)<30: return sh_y+int(h*0.4)
    ry_a=np.array(ry); ss=uniform_filter1d(np.array(sats),25)
    return int(ry_a[int(np.argmax(np.diff(ss)))])

def zone_masks(seg_bin,y_top,y_bot,h,w):
    """
    Returns (edge, interior):
      edge     = seg pixels within y_top..y_bot  — accurate outline
      interior = solid row-fill of edge           — no holes for Delaunay
    """
    edge=seg_bin.copy(); edge[:y_top,:]=0; edge[y_bot:,:]=0
    interior=np.zeros((h,w),np.uint8)
    for y in range(max(0,y_top),min(y_bot,h)):
        nz=np.where(edge[y,:]>0)[0]
        if len(nz)<5: continue
        interior[y,int(nz[0]):int(nz[-1])+1]=255
    interior=cv2.morphologyEx(interior,cv2.MORPH_CLOSE,np.ones((7,7),np.uint8))
    return edge, interior

def cc_seed(zone,sx,sy,h,w):
    sx,sy=int(np.clip(sx,1,w-2)),int(np.clip(sy,1,h-2))
    if zone.sum()==0: return np.zeros((h,w),np.uint8)
    _,lbl,stats,_=cv2.connectedComponentsWithStats(zone)
    l=int(lbl[sy,sx])
    if l>0: return (lbl==l).astype(np.uint8)*255
    return (lbl==int(np.argmax(stats[1:,cv2.CC_STAT_AREA])+1)).astype(np.uint8)*255


def get_masks(frame, lm, seg_up, wb, h, w):
    vis = lm[:, 3]
    def ly(i, fb): return int(lm[i, 1] / 256 * h) if vis[i] > 0.15 else fb
    def lx(i, fb): return int(lm[i, 0] / 256 * w) if vis[i] > 0.15 else fb

    # --- Head landmarks for skin sampling ---
    nose_x, nose_y = lx(0, w//2), ly(0, int(h*.15))
    eye_ys = [ly(i, 0) for i in range(1, 7) if vis[i] > 0.15]
    eye_min = min(eye_ys) if eye_ys else nose_y

    # --- Neck estimate (unchanged) ---
    sh_y = min(ly(11, int(h*.38)), ly(12, int(h*.38)))
    mouth_y = (ly(9,0)+ly(10,0))//2 if vis[9]>0.15 and vis[10]>0.15 else None
    neck_y = int(mouth_y + (sh_y - mouth_y) * 0.55) if mouth_y else sh_y - int(h*.04)
    neck_y = max(0, min(neck_y, sh_y))

    # --- Hip Y (for pants top) ---
    hip_y = max(ly(23, h//2), ly(24, h//2)) if (vis[23]>0.15 or vis[24]>0.15) else wb

    # --- Bottom of pants (using knees/ankles) ---
    kn_y = max(ly(25,0), ly(26,0)) if (vis[25]>0.15 or vis[26]>0.15) else 0
    an_y = max(ly(27,0), ly(28,0)) if (vis[27]>0.15 or vis[28]>0.15) else 0
    sr = np.where(seg_up.sum(axis=1) > 0)[0]
    sb = int(sr[-1]) if len(sr) else h-1
    pb = max(kn_y, an_y, sb) if (kn_y or an_y) else sb

    # --- Prepare binary segmentation ---
    seg_bin = (seg_up > 0.5).astype(np.uint8) * 255
    seg_bin = cv2.morphologyEx(seg_bin, cv2.MORPH_CLOSE, np.ones((9,9), np.uint8))

    # --- Skin mask (whole frame) ---
    # Sample from face/neck area (around nose)
    roi = frame[max(0, nose_y-30):min(h, nose_y+15),
                max(0, nose_x-20):min(w, nose_x+20)]
    if roi.size > 100:
        hsv_roi = cv2.cvtColor(roi, cv2.COLOR_BGR2HSV)
        h_med = np.median(hsv_roi[:,:,0])
        s_med = np.median(hsv_roi[:,:,1])
        v_med = np.median(hsv_roi[:,:,2])
        lower_skin = np.array([max(0, h_med-15), max(5, s_med-60), max(40, v_med-100)], np.uint8)
        upper_skin = np.array([min(179, h_med+15), min(255, s_med+100), min(255, v_med+80)], np.uint8)
    else:
        lower_skin = np.array([0, 15, 60], np.uint8)
        upper_skin = np.array([25, 180, 255], np.uint8)

    skin_mask = cv2.inRange(cv2.cvtColor(frame, cv2.COLOR_BGR2HSV), lower_skin, upper_skin)
    skin_mask = cv2.morphologyEx(skin_mask, cv2.MORPH_CLOSE, np.ones((9,9), np.uint8))
    not_skin = cv2.bitwise_not(skin_mask)

    # --- Head mask (above eyes) ---
    hz = seg_bin.copy()
    hz[eye_min:, :] = 0
    head_e = cc_seed(hz, nose_x, max(10, eye_min-30), h, w)
    head_e = cv2.bitwise_and(head_e, not_skin)          # remove skin
    head_i = head_e.copy()                               # interior = edge (head is small)

    # --- Shirt mask (neck → waistband) ---
    shirt_e, shirt_i = zone_masks(seg_bin, neck_y, wb+5, h, w)
    shirt_e = cv2.bitwise_and(cv2.subtract(shirt_e, head_e), not_skin)
    shirt_i = cv2.bitwise_and(cv2.subtract(shirt_i, head_e), not_skin)

    # --- Pants mask (below hips → bottom) ---
    pants_top = max(wb-5, hip_y)                         # ensure below hips
    pants_e, pants_i = zone_masks(seg_bin, pants_top, pb+int(h*.02), h, w)
    pants_e = cv2.bitwise_and(cv2.subtract(pants_e, cv2.bitwise_or(head_e, shirt_e)), not_skin)
    pants_i = cv2.bitwise_and(cv2.subtract(pants_i, cv2.bitwise_or(head_i, shirt_i)), not_skin)

    return (head_e, head_i), (shirt_e, shirt_i), (pants_e, pants_i)


def delaunay(em,im,extra,h,w,gs):
    cs,_=cv2.findContours(em,cv2.RETR_EXTERNAL,cv2.CHAIN_APPROX_NONE)
    if not cs: return [],None
    mc=max(cs,key=cv2.contourArea)
    simp=cv2.approxPolyDP(mc,3,True); step=max(1,len(simp)//60)
    cp=[(int(simp[i][0][0]),int(simp[i][0][1])) for i in range(0,len(simp),step)
        if 0<simp[i][0][0]<w and 0<simp[i][0][1]<h]
    mn=im.astype(np.float32)/255
    ys, xs = np.where(im > 0)

    if len(xs) > 0:
        xmin, xmax = xs.min(), xs.max()
        ymin, ymax = ys.min(), ys.max()

        ip = [(gx,gy)
            for gy in range(ymin, ymax, gs)
            for gx in range(xmin, xmax, gs)
            if mn[gy,gx] > 0.5]
    else:
        ip = []
    pts=list(set(extra+cp+ip))
    if len(pts)<4: return [],mc
    sd=cv2.Subdiv2D((0,0,w,h))
    for p in pts: 
        try: sd.insert(p)
        except: pass
    tris=[]
    for x1,y1,x2,y2,x3,y3 in sd.getTriangleList():
        ccx=(int(x1)+int(x2)+int(x3))//3; ccy=(int(y1)+int(y2)+int(y3))//3
        if 0<ccx<w and 0<ccy<h and mn[ccy,ccx]>0.35:
            tris.append((int(x1),int(y1),int(x2),int(y2),int(x3),int(y3)))
    return tris,mc


def compute_uv(tri, bbox):

    x1,y1,x2,y2,x3,y3 = tri
    xmin,xmax,ymin,ymax = bbox

    # normalize to 0-1 range
    u1 = (x1-xmin)/(xmax-xmin+1e-6)
    v1 = (y1-ymin)/(ymax-ymin+1e-6)

    u2 = (x2-xmin)/(xmax-xmin+1e-6)
    v2 = (y2-ymin)/(ymax-ymin+1e-6)

    u3 = (x3-xmin)/(xmax-xmin+1e-6)
    v3 = (y3-ymin)/(ymax-ymin+1e-6)

    return [(u1,v1),(u2,v2),(u3,v3)]

def draw_uv_mesh(canvas, tris, bbox):

    for tri in tris:

        uv = compute_uv(tri, bbox)

        # average UV to color triangle
        u = (uv[0][0] + uv[1][0] + uv[2][0]) / 3
        v = (uv[0][1] + uv[1][1] + uv[2][1]) / 3

        color = (
            int(u*255),
            int(v*255),
            150
        )

        x1,y1,x2,y2,x3,y3 = tri

        pts = np.array([[x1,y1],[x2,y2],[x3,y3]])

        cv2.fillPoly(canvas,[pts],color)

        cv2.polylines(canvas,[pts],True,(0,0,0),1,cv2.LINE_AA)
def draw_layer(canvas,tris,cnt,color,lt,fa):
    if not tris: return
    ov=canvas.copy(); fc=tuple(max(0,int(c*.07)) for c in color)
    for x1,y1,x2,y2,x3,y3 in tris:
        cv2.fillPoly(ov,[np.array([[x1,y1],[x2,y2],[x3,y3]])],fc)
    canvas[:]=cv2.addWeighted(canvas,1-fa,ov,fa,0)
    for x1,y1,x2,y2,x3,y3 in tris:
        cv2.polylines(canvas,[np.array([[x1,y1],[x2,y2],[x3,y3]])],True,color,lt,cv2.LINE_AA)
    if cnt is not None: cv2.drawContours(canvas,[cnt],-1,color,2,cv2.LINE_AA)

def process_frame(frame,interp,ema_obj,cfg):
    h,w=frame.shape[:2]
    inp=cv2.cvtColor(cv2.resize(frame,(256,256)),cv2.COLOR_BGR2RGB).astype(np.float32)/255
    interp.set_tensor(interp.get_input_details()[0]["index"],inp[np.newaxis])
    interp.invoke()
    lm=interp.get_tensor(696)[0].reshape(39,5).copy()
    seg=interp.get_tensor(565)[0,:,:,0]
    prs=float(interp.get_tensor(701)[0,0])
    lm[:,3]=1/(1+np.exp(-lm[:,3])); lm[:,4]=1/(1+np.exp(-lm[:,4]))
    seg_up=cv2.resize(1/(1+np.exp(-seg)),(w,h))
    if not (prs>0.3 or np.mean(lm[:,3][:17])>0.3):
        ema_obj.reset(); return frame
    lm_s=ema_obj.upd("lm",lm); seg_s=ema_obj.upd("seg",seg_up)
    seg_s = cv2.GaussianBlur(seg_s, (7,7), 0)
    seg_s = np.clip(seg_s, 0.0, 1.0)
    vis=lm_s[:,3]
    def ly(i,fb): return int(lm_s[i,1]/256*h) if vis[i]>0.15 else fb
    sh_y=min(ly(11,int(h*.38)),ly(12,int(h*.38)))
    seg_b=(seg_s>0.5).astype(np.uint8)*255
    seg_b=cv2.morphologyEx(seg_b,cv2.MORPH_CLOSE,np.ones((9,9),np.uint8))
    wb_raw=detect_wb(frame,seg_b,sh_y,h,w)
    wb=int(ema_obj.upd("wb",float(wb_raw)))
    (he,hi),(se,si),(pe,pi)=get_masks(frame,lm_s,seg_s,wb,h,w)
    ys, xs = np.where(si > 0)

    if len(xs) > 0:
        xmin, xmax = xs.min(), xs.max()
        ymin, ymax = ys.min(), ys.max()
    else:
        xmin, xmax = 0, w
        ymin, ymax = 0, h
    vs=lm_s[:,3]
    lm_pts=[(int(np.clip(lm_s[i,0]/256*w,0,w-1)),int(np.clip(lm_s[i,1]/256*h,0,h-1)))
            for i in range(39) if vs[i]>0.15
            and 3<lm_s[i,0]/256*w<w-3 and 3<lm_s[i,1]/256*h<h-3]
    def inn(m): return [(x,y) for x,y in lm_pts if 0<=y<h and 0<=x<w and m[y,x]>127]
    gs=cfg["gs"]; lt=cfg["lt"]; canvas=frame.copy()
    shirt_tris, shirt_contour = delaunay(se, si, inn(si), h, w, gs)

# disable normal mesh while debugging UV
# draw_layer(canvas, shirt_tris, shirt_contour, cfg["shirt"], lt, 0.15)

    bbox = (xmin, xmax, ymin, ymax)

    draw_uv_mesh(canvas, shirt_tris, bbox)
    if cfg["nodes"]:
        for px,py in lm_pts:
            cv2.circle(canvas,(px,py),4,(0,255,180),-1,cv2.LINE_AA)
            cv2.circle(canvas,(px,py),2,(255,255,255),-1,cv2.LINE_AA)
    return canvas

if uploaded:
    st.video(uploaded)
    if st.button("▶️ Generate Mesh Video",type="primary",use_container_width=True):
        cfg=dict(shirt=hex_bgr(shirt_hex),pants=hex_bgr(pants_hex),
                 head=hex_bgr(head_hex),gs=grid_step,lt=line_thick,nodes=show_nodes)
        tmp=tempfile.NamedTemporaryFile(delete=False,suffix=".mp4")
        tmp.write(uploaded.read()); tmp.close()
        cap=cv2.VideoCapture(tmp.name)
        fps=cap.get(cv2.CAP_PROP_FPS) or 25
        ow_=int(cap.get(cv2.CAP_PROP_FRAME_WIDTH)); oh_=int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))
        tot=int(cap.get(cv2.CAP_PROP_FRAME_COUNT))
        sc=output_w/max(ow_,1); ow=output_w; oh=int(oh_*sc)&~1
        raw=tempfile.NamedTemporaryFile(delete=False,suffix=".mp4").name
        wrt=cv2.VideoWriter(raw,cv2.VideoWriter_fourcc(*"mp4v"),fps,(ow,oh))
        ema_obj=EMA(alpha=smooth_alpha)
        prog=st.progress(0,"Starting…"); prev=st.empty()
        t0=time.time(); fi=0
        while True:
            ret,frame=cap.read()
            if not ret: break
            out=process_frame(cv2.resize(frame,(ow,oh)),INTERP,ema_obj,cfg)
            wrt.write(out); fi+=1
            el=time.time()-t0; pf=fi/max(el,1e-3); eta=(tot-fi)/max(pf,1e-3)
            prog.progress(min(fi/max(tot,1),1.0),text=f"Frame {fi}/{tot} · {pf:.1f} fps · ETA {eta:.0f}s")
            if fi%20==0: prev.image(cv2.cvtColor(out,cv2.COLOR_BGR2RGB),use_container_width=True)
        cap.release(); wrt.release(); prog.empty(); prev.empty()
        out264=tempfile.NamedTemporaryFile(delete=False,suffix=".mp4").name
        with st.spinner("Re-encoding…"):
            _sp.run([FFMPEG,"-y","-i",raw,"-c:v","libx264","-preset","fast",
                     "-crf","22","-movflags","+faststart",out264],capture_output=True,check=False)
        el=time.time()-t0
        st.success(f"✅ Done — {fi} frames · {el:.1f}s · {fi/el:.1f} fps")
        vf=out264 if os.path.exists(out264) and os.path.getsize(out264)>1000 else raw
        with open(vf,"rb") as f:
            st.download_button("📥 Download",f.read(),"mesh_v6.mp4","video/mp4",use_container_width=True)
        for p in [tmp.name,raw]:
            try: os.unlink(p)
            except: pass
