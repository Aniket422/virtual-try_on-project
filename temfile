def extract_cloth_region(img_bgr: np.ndarray, mask: np.ndarray, box_xyxy) -> np.ndarray:
    """Crop shirt from source image using mask + bounding box, inpaint holes."""
    x1, y1, x2, y2 = map(int, box_xyxy)
    cloth = img_bgr.copy()
    cloth[mask == 0] = 0
    crop = cloth[y1:y2, x1:x2]
    if crop.size == 0:
        return None
    hole_mask = (crop.sum(axis=-1) == 0).astype(np.uint8) * 255
    crop = cv2.inpaint(crop, hole_mask, 3, cv2.INPAINT_TELEA)
    return crop


def estimate_body_angle(box_xyxy, frame_w: int) -> float:
    """
    Estimate rough horizontal orientation from bounding-box position & aspect.
    Returns angle in degrees:
      0   = facing camera (front view)
     -45  = turned left  (show left-side view)
     +45  = turned right (show right-side view)
    """
    x1, y1, x2, y2 = box_xyxy
    cx = (x1 + x2) / 2
    w  = x2 - x1
    h  = y2 - y1
    aspect = w / max(h, 1)          # narrow → side-on; wide → frontal

    # Map aspect ratio: ~0.35 side-on → ±45°; ~0.55 frontal → 0°
    # Normalise to [-45, 45] based on aspect
    angle_from_aspect = (0.55 - aspect) / 0.20 * 45.0
    angle_from_aspect = float(np.clip(angle_from_aspect, -45, 45))

    # Use horizontal position to decide left vs right lean
    rel_x = (cx / frame_w) - 0.5    # -0.5 left ... +0.5 right
    angle = angle_from_aspect * np.sign(rel_x) if abs(rel_x) > 0.1 else angle_from_aspect
    return float(angle)


def angle_to_view_index(angle_deg: float) -> int:
    """
    Map body angle to one of 4 shirt-view slots:
      0 = front   ( -15° .. +15°  )
      1 = left-side ( < -15° )
      2 = back    ( extreme — not typical in video; fallback )
      3 = right-side ( > +15° )
    Returns index 0-3 matching the 4 crops you extracted.
    """
    if angle_deg < -15:
        return 1   # left / side-left
    elif angle_deg > 15:
        return 3   # right / side-right
    else:
        return 0   # front


def split_product_sheet(img_bgr: np.ndarray, n_views: int = 4):
    """Split a horizontally-arranged product sheet into N equal vertical strips."""
    h, w = img_bgr.shape[:2]
    strip_w = w // n_views
    views = []
    for i in range(n_views):
        crop = img_bgr[:, i * strip_w : (i + 1) * strip_w]
        views.append(crop)
    return views   # [front-left, side-left, back, side-right]  (typical layout)


def apply_shirt_to_frame(
    frame: np.ndarray,
    predictor,
    model,
    shirt_views: list,
    conf: float = 0.45,
) -> tuple:
    """Run detection + SAM on one frame, pick angle-correct shirt, blend."""
    output = frame.copy()
    used_angle = 0.0
    used_view_idx = 0
    frame_h, frame_w = frame.shape[:2]

    results = model(frame, conf=conf, verbose=False)
    if results[0].boxes is None:
        return output, used_angle, used_view_idx

    frame_rgb = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
    predictor.set_image(frame_rgb)

    for box in results[0].boxes:
        cls = int(box.cls[0])
        if cls not in [0, 1]:          # 0=short-sleeve, 1=long-sleeve
            continue

        x1, y1, x2, y2 = map(int, box.xyxy[0])
        input_box = np.array([x1, y1, x2, y2])

        masks_sam, _, _ = predictor.predict(
            box=input_box,
            multimask_output=False
        )
        mask = (masks_sam[0] > 0.5).astype(np.uint8) * 255

        # Morphological cleanup for sharp edges
        k5 = np.ones((5, 5), np.uint8)
        k3 = np.ones((3, 3), np.uint8)
        mask = cv2.morphologyEx(mask, cv2.MORPH_CLOSE, k5)
        mask = cv2.morphologyEx(mask, cv2.MORPH_OPEN,  k3)

        # Angle → view
        used_angle = estimate_body_angle((x1, y1, x2, y2), frame_w)
        used_view_idx = angle_to_view_index(used_angle)
        source_cloth = shirt_views[used_view_idx]

        bw = x2 - x1
        bh = y2 - y1
        if bw <= 0 or bh <= 0:
            continue

        cloth_resized  = cv2.resize(source_cloth, (bw, bh))
        mask_crop      = mask[y1:y2, x1:x2]
        mask_crop      = cv2.resize(mask_crop, (bw, bh), interpolation=cv2.INTER_NEAREST)

        # Alpha blend
        alpha = mask_crop.astype(np.float32) / 255.0
        alpha = alpha[..., np.newaxis]
        roi   = output[y1:y2, x1:x2]
        blended = (roi * (1 - alpha) + cloth_resized * alpha).astype(np.uint8)
        output[y1:y2, x1:x2] = blended
        break   # one person per frame assumed

    return output, used_angle, used_view_idx


