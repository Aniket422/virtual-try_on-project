    # Split into 4 views
    raw_views = split_product_sheet(product_img, n_views=4)
    view_labels = ["Front", "Left Side", "Back", "Right Side"]

    st.markdown("### Detected views")
    vcols = st.columns(4)
    for i, (v, lbl) in enumerate(zip(raw_views, view_labels)):
        with vcols[i]:
            st.image(cv2.cvtColor(v, cv2.COLOR_BGR2RGB), caption=lbl, use_column_width=True)

    # Extract shirt from each view using YOLO
    for i, view in enumerate(raw_views):
        results_src = model(view, conf=0.4, verbose=False)
        extracted = None
        if results_src[0].masks is not None:
            for mask_data, box in zip(
                results_src[0].masks.data.cpu().numpy(),
                results_src[0].boxes
            ):
                cls = int(box.cls[0])
                if cls not in [0, 1]:
                    continue
                m = (mask_data > 0.5).astype(np.uint8)
                m = cv2.resize(m, (view.shape[1], view.shape[0]),
                               interpolation=cv2.INTER_NEAREST)
                extracted = extract_cloth_region(view, m, box.xyxy[0].cpu().numpy())
                if extracted is not None and extracted.size > 0:
                    break

        if extracted is None:
            # Fallback: use full cropped view
            extracted = view.copy()
            st.warning(f"⚠️ Auto-extract failed for **{view_labels[i]}** — using full crop as fallback.")

        shirt_views.append(extracted)

    st.success(f"✅ {len(shirt_views)} shirt views ready!")

