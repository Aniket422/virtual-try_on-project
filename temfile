if video_file and shirt_views and st.button("🚀 Transfer Shirt to Video", type="primary"):

    tfile = tempfile.NamedTemporaryFile(delete=False, suffix=".mp4")
    tfile.write(video_file.read())
    tfile.flush()

    cap     = cv2.VideoCapture(tfile.name)
    width   = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))
    height  = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))
    fps     = int(cap.get(cv2.CAP_PROP_FPS)) or 25
    total   = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))
    limit   = int(max_frames) if max_frames > 0 else total

    out_tmp = tempfile.NamedTemporaryFile(delete=False, suffix=".mp4")
    out     = cv2.VideoWriter(
        out_tmp.name,
        cv2.VideoWriter_fourcc(*"mp4v"),
        fps,
        (width, height)
    )

    progress_bar  = st.progress(0.0)
    status_text   = st.empty()
    angle_display_box = st.empty()

    view_labels   = ["Front", "Left Side", "Back", "Right Side"]
    frame_count   = 0

    while frame_count < limit:
        ret, frame = cap.read()
        if not ret:
            break

        processed, angle, view_idx = apply_shirt_to_frame(
            frame, predictor, model, shirt_views, conf=conf_thresh
        )

        if angle_display:
            label = f"Angle:{angle:+.1f}deg | View:{view_labels[view_idx]}"
            cv2.putText(processed, label, (12, 36),
                        cv2.FONT_HERSHEY_SIMPLEX, 0.8, (0, 220, 255), 2, cv2.LINE_AA)

        out.write(processed)
        frame_count += 1
        pct = frame_count / limit
        progress_bar.progress(min(pct, 1.0))
        status_text.markdown(
            f"Frame **{frame_count}/{limit}** — "
            f"Angle: `{angle:+.1f}°` → **{view_labels[view_idx]}** view"
        )

    cap.release()
    out.release()

    st.success("✅ Processing complete!")

    with open(out_tmp.name, "rb") as f:
        video_bytes = f.read()

    st.download_button(
        label="⬇️ Download result video",
        data=video_bytes,
        file_name="shirt_transfer_output.mp4",
        mime="video/mp4",
    )

    # Quick preview (first frame)
    cap_preview = cv2.VideoCapture(out_tmp.name)
    ret, preview_frame = cap_preview.read()
    cap_preview.release()
    if ret:
        st.image(
            cv2.cvtColor(preview_frame, cv2.COLOR_BGR2RGB),
            caption="Preview — first frame of result",
            use_column_width=True
        )

